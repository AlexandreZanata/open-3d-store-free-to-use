# REST API base URL (includes /api/v1)
VITE_API_BASE_URL=http://127.0.0.1:6200/api/v1

# WhatsApp contact (same digits as API WHATSAPP_PHONE_NUMBER)
VITE_WHATSAPP_PHONE=5565999999999

# Optional in dev — omit to use same-origin /models (Vite proxy). Set for production builds.
# VITE_ASSETS_BASE_URL=https://yourdomain.com
