# API — copy to `.env` for local development (never commit `.env`)

NODE_ENV=development
PORT=3001

DATABASE_URL=postgresql://print3d:devpassword@localhost:5432/print3d_dev
TEST_DATABASE_URL=postgresql://print3d:devpassword@localhost:5432/print3d_test

REDIS_URL=redis://localhost:6379

WHATSAPP_PHONE_NUMBER=5565999999999

CORS_ORIGIN=http://localhost:5173

MODEL_FILES_BASE_PATH=storage/models
MODEL_FILES_BASE_URL=http://localhost:5173/models

# Admin panel (Phase 9+) — see docs/api/admin-contract.md
ADMIN_SESSION_SECRET=dev-only-change-me-to-32-char-minimum-secret
ADMIN_SESSION_TTL=28800
ADMIN_SESSION_IDLE_TTL=1800
ADMIN_ORIGIN=http://localhost:5174
ADMIN_BOOTSTRAP_EMAIL=admin@localhost
ADMIN_BOOTSTRAP_PASSWORD=change-me-in-dev
UPLOAD_MAX_BYTES=5242880
UPLOAD_DIR=/var/www/print3d/models
