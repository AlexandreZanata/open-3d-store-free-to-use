# Domain mode — copy to vps.env when Cloudflare DNS is active
# See production/DNS-CUTOVER.md

VPS_HOST=72.60.147.2
VPS_USER=root
VPS_PORT=22
VPS_APP_DIR=/var/www/print3d

# Real domain (no scheme, no www prefix)
DOMAIN=yourdomain.com.br
VPS_USE_HTTPS=1

# Standard HTTP/HTTPS ports (nginx.conf + certbot)
NGINX_HTTP_PORT=80
