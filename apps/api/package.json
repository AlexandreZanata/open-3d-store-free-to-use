{
  "name": "@print3d/api",
  "private": true,
  "version": "0.0.0",
  "description": "Fastify API — runtime: PostgreSQL 18.4, Redis 8.8 (docs/stack/technology-decisions.md)",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "print3d": {
    "runtime": {
      "postgresql": "18.4",
      "redis": "8.8"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx --env-file=.env src/main.ts",
    "start": "node dist/main.js",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx --env-file=.env scripts/seed.ts",
    "db:seed-assets": "tsx --env-file=.env scripts/generateSeedThumbnails.ts && tsx --env-file=.env scripts/seedAssets.ts",
    "db:studio": "drizzle-kit studio",
    "worker:model-processing": "tsx --env-file=.env scripts/workerModelProcessing.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.1",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@print3d/shared-types": "workspace:*",
    "@print3d/whatsapp": "workspace:*",
    "amqplib": "^0.10.8",
    "argon2": "^0.43.0",
    "drizzle-orm": "^0.44.2",
    "fastify": "^5.4.0",
    "ioredis": "^5.6.1",
    "pg": "^8.22.0",
    "redis": "^5.12.1",
    "sharp": "^0.35.2",
    "uuidv7": "^1.0.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.7",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.4",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
