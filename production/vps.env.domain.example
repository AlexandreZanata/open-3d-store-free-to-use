# Domain mode — copy to vps.env when Cloudflare DNS is active
# See production/DNS-CUTOVER.md

# REQUIRED — replace with your VPS IPv4 before ./production/deploy-to-vps.sh
VPS_HOST=YOUR_VPS_IP
VPS_USER=root
VPS_PORT=22
VPS_APP_DIR=/var/www/print3d

# Live storefront domain (example: corvo3d.com.br)
DOMAIN=corvo3d.com.br
VPS_USE_HTTPS=1

NGINX_HTTP_PORT=80
API_PORT=3101
