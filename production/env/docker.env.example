# Docker Compose production data layer — copy to docker.env (never commit)
# Host ports avoid conflicts with native Postgres/Redis on shared VPS (Hostinger).

POSTGRES_DB=print3d_prod
POSTGRES_USER=print3d
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_HOST_PORT=5433

REDIS_HOST_PORT=6380

RABBITMQ_USER=print3d
RABBITMQ_PASSWORD=CHANGE_ME
RABBITMQ_HOST_PORT=5673
RABBITMQ_MGMT_HOST_PORT=15673
