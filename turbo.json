{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@print3d/admin#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.production", ".env.local", ".env.production.local"],
      "env": ["VITE_*", "NODE_ENV"]
    },
    "@print3d/web#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.production", ".env.local", ".env.production.local"],
      "env": ["VITE_*", "NODE_ENV"]
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false,
      "env": [
        "CI",
        "DATABASE_URL",
        "REDIS_URL",
        "TEST_DATABASE_URL",
        "WHATSAPP_PHONE_NUMBER",
        "CORS_ORIGIN",
        "MODEL_FILES_BASE_PATH",
        "MODEL_FILES_BASE_URL",
        "NODE_ENV"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    }
  }
}
