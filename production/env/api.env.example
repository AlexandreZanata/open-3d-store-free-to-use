# VPS API — copy to api.env and fill in real values (never commit api.env)

NODE_ENV=production
PORT=3101

DATABASE_URL=postgresql://print3d:CHANGE_ME@127.0.0.1:5432/print3d_prod
REDIS_URL=redis://127.0.0.1:6379

WHATSAPP_PHONE_NUMBER=5565999999999

CORS_ORIGIN=https://yourdomain.com
MODEL_FILES_BASE_PATH=/var/www/print3d/models
MODEL_FILES_BASE_URL=https://yourdomain.com/models

ADMIN_SESSION_SECRET=CHANGE_ME_MIN_32_RANDOM_BYTES
ADMIN_SESSION_TTL=28800
ADMIN_SESSION_IDLE_TTL=1800
ADMIN_ORIGIN=https://admin.yourdomain.com

STORE_SESSION_TTL=2592000
STORE_SESSION_IDLE_TTL=604800

UPLOAD_MAX_BYTES=5242880
UPLOAD_DIR=/var/www/print3d/models

RABBITMQ_URL=amqp://print3d:CHANGE_ME@127.0.0.1:5672
MODEL_PROCESSING_QUEUE=model.processing

# Do NOT set bootstrap vars in production
# ADMIN_BOOTSTRAP_EMAIL=
# ADMIN_BOOTSTRAP_PASSWORD=
